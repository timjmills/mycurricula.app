# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the example template carries no secrets and should be tracked.
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# dev server logs
/dev-*.log

# claude code (agent worktrees, local state)
/.claude/

# cloudflare / opennext
/.open-next/
/.wrangler/
.dev.vars
cloudflare-env.d.ts

# jetbrains ide
/.idea/

# Quote-bank local-only build artifacts (raw mining inputs + full bank are
# regenerated locally; the app bundles only insights.hero.json).
scripts/quote-mining/output/
lib/home/insights.data.json

# QA working artifacts (§4b Live QA Audit Gate output — per-pass, never committed)
QA-REPORT.md

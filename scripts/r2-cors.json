{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://mycurricula.app",
          "http://localhost:3000"
        ],
        "methods": ["GET", "PUT", "HEAD"],
        "headers": [
          "Content-Type",
          "Content-Length",
          "Content-Disposition",
          "Authorization",
          "x-amz-content-sha256",
          "x-amz-date",
          "x-amz-acl"
        ]
      },
      "exposeHeaders": ["ETag", "Content-Length", "Content-Type"],
      "maxAgeSeconds": 3600
    }
  ]
}

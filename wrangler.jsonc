{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mycurricula-app",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  // Serve the Worker on the production domain. `custom_domain` provisions the
  // DNS record + TLS cert automatically, since the zone is in this account.
  "routes": [{ "pattern": "mycurricula.app", "custom_domain": true }],

  // R2 binding for lesson resources. The Worker uses it server-side (the
  // browser uploads directly via presigned URLs from lib/r2.ts). Bucket
  // must exist before deploy — see docs/claude-access.md §Resource embed.
  //
  // TEMPORARILY DISABLED 2026-05-28 — R2 is not yet enabled on the Cloudflare
  // account, so wrangler deploys fail with code 10042 ("Please enable R2
  // through the Cloudflare Dashboard"). The resource-embed renderer + URL
  // parser + CSP still ship cleanly; only the file-upload path (lib/r2.ts +
  // /api/resources/upload + ResourceComposer file-pick) is stubbed without
  // the binding. To restore:
  //   1. dash.cloudflare.com → R2 → enable + create bucket "lesson-resources"
  //   2. Add CORS rules for https://mycurricula.app + http://localhost:3000
  //   3. Set Worker secrets: R2_ACCOUNT_ID, R2_ACCESS_KEY_ID,
  //      R2_SECRET_ACCESS_KEY, R2_BUCKET=lesson-resources, R2_PUBLIC_HOST
  //   4. Mirror the five into .env.local
  //   5. Uncomment the r2_buckets block below + redeploy
  // "r2_buckets": [
  //   {
  //     "binding": "LESSON_RESOURCES",
  //     "bucket_name": "lesson-resources",
  //   },
  // ],
}

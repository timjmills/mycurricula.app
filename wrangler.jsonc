{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mycurricula-app",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  // Serve the Worker on the production domain. `custom_domain` provisions the
  // DNS record + TLS cert automatically, since the zone is in this account.
  "routes": [{ "pattern": "mycurricula.app", "custom_domain": true }],

  // R2 binding for lesson resources. The Worker uses it server-side (the
  // browser uploads directly via presigned URLs from lib/r2.ts). The
  // bucket + CORS + Worker secrets were provisioned 2026-05-27 (see
  // docs/claude-access.md §Resource embed).
  "r2_buckets": [
    {
      "binding": "LESSON_RESOURCES",
      "bucket_name": "lesson-resources",
    },
  ],
}

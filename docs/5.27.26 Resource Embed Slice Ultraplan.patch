+
+.ogThumb {
+  width: 120px;
+  height: 100%;
+  object-fit: cover;
+}
+
+.ogThumbFallback {
+  background: var(--ink-50, #f4f4f5);
+}
+
+.ogBody {
+  display: flex;
+  flex-direction: column;
+  justify-content: center;
+  padding: 12px 14px 12px 0;

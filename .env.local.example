# MyCurricula — environment variables.
#
# Copy this file to .env.local and fill in the values from your Supabase
# project: Dashboard → Project Settings → API.
#   cp .env.local.example .env.local
#
# .env.local is gitignored — never commit real keys.

# Project URL, e.g. https://abcdefghijklm. supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe for the browser; Row-Level Security gates access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY. Bypasses Row-Level Security.
# Never prefix with NEXT_PUBLIC_ and never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth client ID — used by the browser GSI sign-in button.
# Same client ID configured in Supabase Auth → Providers → Google.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── Claude auth-bypass ───────────────────────────────────────────────
# Long random token (32 bytes base64). Presenting it as `?claude=<token>`
# on any URL — or as `Authorization: Bearer <token>` — short-circuits the
# Google SSO gate and signs the request in as CLAUDE_USER_EMAIL. Works
# across every Claude surface (Code, Chat, Co-work, Code Cloud). Treat it
# as a password: never commit, rotate regularly, set as a Cloudflare
# secret via `wrangler secret put CLAUDE_BYPASS_TOKEN`. Leaving this
# empty disables the bypass entirely.
#   Generate: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
CLAUDE_BYPASS_TOKEN=

# The email Claude signs in as when the bypass fires. Must be a Supabase
# auth user OR a new email the bypass is allowed to provision (see
# CLAUDE_BYPASS_PROVISION).
CLAUDE_USER_EMAIL=

# Set to "0" to disable auto-provisioning. When 0, the bypass refuses
# requests for unknown emails. Default: provisioning enabled (any value
# other than "0", including empty, allows it).
CLAUDE_BYPASS_PROVISION=

# MyCurricula — environment variables.
#
# Copy this file to .env.local and fill in the values from your Supabase
# project: Dashboard → Project Settings → API.
#   cp .env.local.example .env.local
#
# .env.local is gitignored — never commit real keys.
#
# Full setup runbook: docs/SUPABASE_SETUP.md
# Validate your filled-in .env.local with: node scripts/check-supabase.mjs

# ── Supabase (read by lib/supabase/*, lib/claude-bypass.ts) ───────────
# Project URL, e.g. https://abcdefghijklmnopqrst.supabase.co
# (Dashboard → Project Settings → API → Project URL.)
# Read by client.ts, server.ts, middleware.ts, admin.ts, claude-bypass.ts.
NEXT_PUBLIC_SUPABASE_URL=https://xuukfpvonsbvvbspsrsl.supabase.co

# Public anon (a.k.a. publishable) key — safe for the browser; Row-Level
# Security gates access. (Dashboard → Project Settings → API → anon public.)
# Read by client.ts, server.ts, middleware.ts, claude-bypass.ts.
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLISHABLE-KEY

# Service-role (a.k.a. secret) key — SERVER ONLY. Bypasses Row-Level
# Security. (Dashboard → Project Settings → API → service_role secret.)
# Never prefix with NEXT_PUBLIC_ and never expose to the browser.
# Read by lib/supabase/admin.ts (used to mint Claude-bypass sessions +
# write the audit log).
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET-KEY

# ── Backend toggles (read by the Teach + planner data seams) ──────────
# Set each to 1 once migrations + seed + the importer have run, to persist that
# surface to Postgres. Default/absent → in-memory mock (the prototype path).
#   NEXT_PUBLIC_TEACH_USE_SUPABASE    → Teach boards/widgets persist
#   NEXT_PUBLIC_PLANNER_USE_SUPABASE  → lessons/units/resources persist
NEXT_PUBLIC_TEACH_USE_SUPABASE=
NEXT_PUBLIC_PLANNER_USE_SUPABASE=

# ── Google SSO (read by the browser sign-in button) ───────────────────
# Google OAuth client ID — used by the browser GSI sign-in button. Same
# client ID configured in Supabase Auth → Providers → Google. This is a
# public identifier (safe in the browser); the matching client SECRET is
# entered ONLY in the Supabase dashboard, never here.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR-GOOGLE-OAUTH-CLIENT-ID.apps.googleusercontent.com

# ── Claude auth-bypass (read by lib/claude-bypass.ts) ─────────────────
# Long random token (32 bytes base64). Presenting it as `?claude=<token>`
# on any URL — or as `Authorization: Bearer <token>` — short-circuits the
# Google SSO gate and signs the request in as CLAUDE_USER_EMAIL. Works
# across every Claude surface (Code, Chat, Co-work, Code Cloud). Treat it
# as a password: never commit, rotate regularly, set as a Cloudflare
# secret via `wrangler secret put CLAUDE_BYPASS_TOKEN`. Leaving this
# empty disables the bypass entirely. Minimum 16 chars (enforced in code).
#   Generate: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
CLAUDE_BYPASS_TOKEN=

# The email Claude signs in as when the bypass fires. Must be a Supabase
# auth user OR a new email the bypass is allowed to provision (see
# CLAUDE_BYPASS_PROVISION).
CLAUDE_USER_EMAIL=you@example.com

# Set to "0" to disable auto-provisioning. When 0, the bypass refuses
# requests for unknown emails. Default: provisioning enabled (any value
# other than "0", including empty, allows it).
CLAUDE_BYPASS_PROVISION=1

# ── Cloudflare R2 (Phase 1B resource-embed; read by lib/r2.ts) ────────
# Only required once the resource-upload slice is live. lib/r2.ts reads
# R2_PUBLIC_HOST directly and the rest via its requireEnv() helper. Leave
# blank until you wire R2; the core app + Teach view do not need them.
#   R2_ACCOUNT_ID         Cloudflare account ID
#   R2_ACCESS_KEY_ID      R2 S3-compat API token (Object Read + Write)
#   R2_SECRET_ACCESS_KEY  R2 S3-compat API token secret
#   R2_BUCKET             lesson-resources
#   R2_PUBLIC_HOST        <accountid>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=lesson-resources
R2_PUBLIC_HOST=
